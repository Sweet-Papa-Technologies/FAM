{
  "name": "@sweetpapatech/fam",
  "version": "1.0.2",
  "description": "FoFo Agent Manager — One config. Every agent.",
  "type": "module",
  "bin": {
    "fam": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sweet-Papa-Technologies/FAM.git"
  },
  "homepage": "https://github.com/Sweet-Papa-Technologies/FAM#readme",
  "bugs": {
    "url": "https://github.com/Sweet-Papa-Technologies/FAM/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "preinstall": "node -e \"var v=process.versions.node.split('.')[0]; if(v<22){console.error('\\n  FAM requires Node.js >= 22 (you have '+process.version+').\\n  Run: nvm use 22\\n'); process.exit(1)}\"",
    "build": "tsup src/index.ts --format esm --dts",
    "build:patch": "npm version patch --no-git-tag-version && tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/check-native-modules.mjs && vitest run",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build && npm test",
    "test:docker": "bash test/docker-e2e/run.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@napi-rs/keyring": "^1.1.6",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fastify": "^5.3.2",
    "inquirer": "^12.4.2",
    "json-diff": "^1.0.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "simple-oauth2": "^5.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.7",
    "@types/json-diff": "^1.0.3",
    "@types/simple-oauth2": "^5.0.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "mcp",
    "agent",
    "cli",
    "proxy",
    "credentials"
  ],
  "author": "Forrester Terry <forrester@sweetpapatech.com>",
  "license": "MIT"
}
