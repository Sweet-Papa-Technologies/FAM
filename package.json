{
  "name": "@sweetpapatech/fam",
  "version": "1.0.0",
  "description": "FoFo Agent Manager — One config. Every agent.",
  "type": "module",
  "bin": {
    "fam": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetpapatech/fam.git"
  },
  "homepage": "https://github.com/sweetpapatech/fam#readme",
  "bugs": {
    "url": "https://github.com/sweetpapatech/fam/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fastify": "^5.3.2",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@napi-rs/keyring": "^1.1.6",
    "better-sqlite3": "^11.8.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.3",
    "json-diff": "^1.0.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "chalk": "^5.4.1",
    "inquirer": "^12.4.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/json-diff": "^1.0.3",
    "@types/inquirer": "^9.0.7",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "prettier": "^3.5.3",
    "eslint-config-prettier": "^10.1.1",
    "tsx": "^4.19.3",
    "tsup": "^8.4.0"
  },
  "keywords": ["mcp", "agent", "cli", "proxy", "credentials"],
  "author": "Forrester Terry <forrester@sweetpapatech.com>",
  "license": "MIT"
}
